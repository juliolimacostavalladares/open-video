# =============================================================================
# Open Video Studio - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/open_video_studio?schema=public"

# -----------------------------------------------------------------------------
# Redis (BullMQ)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Storage (MinIO/S3 or Local)
# -----------------------------------------------------------------------------
STORAGE_DRIVER="local"  # "local" or "s3"

# Local storage path (when STORAGE_DRIVER=local)
LOCAL_STORAGE_PATH="./storage"

# S3/MinIO configuration (when STORAGE_DRIVER=s3)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="open-video-studio"
S3_REGION="us-east-1"

# -----------------------------------------------------------------------------
# AI - LLM (9Router)
# -----------------------------------------------------------------------------
AI_LLM_BASE_URL="http://localhost:20128/v1"
AI_LLM_API_KEY="sk-4d17a0a7e062b95e-dpfpwg-9d1ccc2f"
AI_LLM_MODEL="ag/claude-sonnet-4-6"

# -----------------------------------------------------------------------------
# AI - TTS/Voice Cloning (OmniVoice)
# -----------------------------------------------------------------------------
OMNIVOICE_BASE_URL="http://localhost:8000"

# -----------------------------------------------------------------------------
# Media - Pixabay API
# -----------------------------------------------------------------------------
PIXABAY_API_KEY="your-pixabay-api-key"

# -----------------------------------------------------------------------------
# Authentication (NextAuth with GitHub)
# -----------------------------------------------------------------------------
GITHUB_ID="your-github-oauth-app-id"
GITHUB_SECRET="your-github-oauth-app-secret"
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# YouTube OAuth
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID="your-youtube-oauth-client-id"
YOUTUBE_CLIENT_SECRET="your-youtube-oauth-client-secret"
YOUTUBE_REDIRECT_URI="http://localhost:4000/youtube/oauth/callback"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="info"

# Web app
WEB_PORT=3000

# API server
API_PORT=4000
